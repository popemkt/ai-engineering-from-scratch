# Toolchain from an in-repo flake. `path:` flakeref reads the filesystem directly, so the
# flake files need not be git-tracked (and only .nix/ is copied to the store, not the repo).
use flake "path:$PWD/.nix"

# uv-managed venv (numpy/torch live here, not in nix).
export UV_PROJECT_ENVIRONMENT="$PWD/.venv"
PATH_add .venv/bin

# Auto-load .env if present (API keys etc). Never commit .env — it's in .gitignore.
dotenv_if_exists
